# 0x Protocol API Configuration
NEXT_PUBLIC_0X_API_URL=https://api.0x.org
NEXT_PUBLIC_0X_API_KEY=your_0x_api_key_here

# Safe App Configuration
NEXT_PUBLIC_SAFE_APP_URL=https://app.safe.global

# Network Configuration
NEXT_PUBLIC_DEFAULT_CHAIN_ID=1
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_key
NEXT_PUBLIC_POLYGON_RPC_URL=https://polygon-mainnet.infura.io/v3/your_infura_key
NEXT_PUBLIC_ARBITRUM_RPC_URL=https://arbitrum-mainnet.infura.io/v3/your_infura_key
NEXT_PUBLIC_OPTIMISM_RPC_URL=https://optimism-mainnet.infura.io/v3/your_infura_key

# Optional: Analytics and Monitoring
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Development
NODE_ENV=development